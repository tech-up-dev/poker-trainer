# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
#
# Use the STAGING project values locally. Vercel injects the correct values
# per branch automatically (staging on Preview, production on master).

# Supabase — staging project (local dev + Vercel Preview)
VITE_SUPABASE_URL=https://<staging-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>

# Supabase — production project (used by supabase-prod.ts for promote/rollback)
VITE_SUPABASE_PROD_URL=https://<prod-project-ref>.supabase.co
VITE_SUPABASE_PROD_ANON_KEY=<prod-anon-key>
